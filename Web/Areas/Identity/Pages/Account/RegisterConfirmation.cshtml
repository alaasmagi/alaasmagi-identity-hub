@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = L["Register confirmation"];
}

<h1>@ViewData["Title"]</h1>
<p>
    @L["Please check your email to confirm your account."]
</p>
@if (Model.IsEmailDeliveryConfigured)
{
    <p class="text-muted">
        @L["A confirmation email has been sent using the configured email provider."]
    </p>
}
else
{
    <p class="text-muted">
        @L["If email delivery is not configured, the confirmation token is written to the application log."]
    </p>
}
<p>
    <a asp-page="./Login"
       asp-route-clientId="@Model.ClientId"
       asp-route-redirectUri="@Model.RedirectUri"
       asp-route-returnUrl="@Model.ReturnUrl">@L["Back to sign in"]</a>
</p>

