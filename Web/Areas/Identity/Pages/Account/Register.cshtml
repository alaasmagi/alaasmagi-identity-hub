@page
@model RegisterModel
@{
    ViewData["Title"] = L["Register"];
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form id="registerForm" method="post">
            @if (!string.IsNullOrWhiteSpace(Model.ClientName))
            {
                <h2>@L["CreateAccountToContinueTo", Model.ClientName]</h2>
            }
            else
            {
                <h2>@L["Create a new account."]</h2>
            }
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <input type="hidden" asp-for="ClientId" />
            <input type="hidden" asp-for="RedirectUri" />
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="form-floating mb-3">
                <input asp-for="Input.FullName" class="form-control" autocomplete="name" aria-required="true" placeholder="@L["Full name"]" />
                <label asp-for="Input.FullName">@L["Full name"]</label>
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">@L["Email"]</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@L["Password"]" />
                <label asp-for="Input.Password">@L["Password"]</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="@L["Password"]" />
                <label asp-for="Input.ConfirmPassword">@L["Confirm Password"]</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">@L["Register"]</button>
        </form>
    </div>
    @if (Model.MissingClientContext)
    {
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>@L["External registration"]</h3>
            <hr />
            <p class="text-muted">@L["Open registration from a registered client application to use Google or Microsoft."]</p>
        </section>
    </div>
    }
    else if ((Model.ExternalProviders?.Count ?? 0) > 0)
    {
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>@L["Use another service to register."]</h3>
            <hr />
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                <input type="hidden" asp-for="ClientId" />
                <input type="hidden" asp-for="RedirectUri" />
                <div>
                    <p>
                        @foreach (var provider in Model.ExternalProviders!)
                        {
                            <button type="submit" class="btn btn-primary" name="provider" value="@provider" title="@L["LogInUsingProvider", provider]">@provider</button>
                        }
                    </p>
                </div>
            </form>
        </section>
    </div>
    }
</div>

<partial name="_ValidationScriptsPartial" />
