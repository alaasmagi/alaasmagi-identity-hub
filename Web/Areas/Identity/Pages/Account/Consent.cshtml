@page
@model ConsentModel
@{
    ViewData["Title"] = L["Authorize application"];
}

<h1>@ViewData["Title"]</h1>
<div class="row">
    <div class="col-md-6">
        <section>
            <form method="post">
                <h2>@L["AuthorizeApplicationMessage", Model.ClientName ?? L["This application"].Value]</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <input type="hidden" asp-for="ClientId" />
                <input type="hidden" asp-for="RedirectUri" />
                <input type="hidden" asp-for="ConsentToken" />

                @if (!string.IsNullOrWhiteSpace(Model.Message))
                {
                    <div class="alert alert-info" role="status">@Model.Message</div>
                }
                else
                {
                    @if (Model.RegistrationType is not null)
                    {
                        <p class="text-muted">@L["Registration type:"] @Model.RegistrationType</p>
                    }
                    <div class="d-flex gap-2">
                        <button type="submit" asp-page-handler="Approve" class="btn btn-primary">@L["Approve"]</button>
                        <button type="submit" asp-page-handler="Deny" class="btn btn-outline-secondary">@L["Deny"]</button>
                    </div>
                }
            </form>
        </section>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />
