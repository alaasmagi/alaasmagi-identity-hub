@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = L["Generate two-factor authentication (2FA) recovery codes"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div class="alert alert-warning" role="alert">
    <p>
        <span class="glyphicon glyphicon-warning-sign"></span>
        <strong>@L["Put these codes in a safe place."]</strong>
    </p>
    <p>
        @L["If you lose your device and don't have the recovery codes you will lose access to your account."]
    </p>
    <p>
        @L["Generating new recovery codes does not change the keys used in authenticator apps."] @L["If you wish to change the key used in an authenticator app you should"] <a asp-page="./ResetAuthenticator">@L["reset your authenticator keys."]</a>
    </p>
</div>
<div>
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="@L["Authenticator code"]" />
            <label asp-for="Input.Code" class="form-label"></label>
            <span asp-validation-for="Input.Code" class="text-danger"></span>
        </div>
        <button class="btn btn-danger" type="submit">@L["Generate Recovery Codes"]</button>
    </form>
</div>

<partial name="_ValidationScriptsPartial" />
