@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = L["Configure authenticator app"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div>
    <p>@L["To use an authenticator app go through the following steps:"]</p>
    <ol class="list">
        <li>
            <p>
                @L["Download a two-factor authenticator app like Microsoft Authenticator for"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> @L["and"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a> @L["or"]
                Google Authenticator @L["for"]
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a> @L["and"]
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
            </p>
        </li>
        <li>
            <p>@L["Scan the QR Code or enter this key"] <kbd>@Model.SharedKey</kbd> @L["into your two factor authenticator app. Spaces and casing do not matter."]</p>
            <div class="alert alert-info">@L["Learn how to"] <a href="https://go.microsoft.com/fwlink/?Linkid=852423">@L["enable QR code generation"]</a>.</div>
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>
                @L["Once you have scanned the QR code or input the key above, your two factor authentication app will provide you with a unique code. Enter the code in the confirmation box below."]
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="@L["Please enter the code."]"/>
                            <label asp-for="Input.Code" class="control-label form-label">@L["Verification Code"]</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">@L["Verify"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

<partial name="_ValidationScriptsPartial" />
