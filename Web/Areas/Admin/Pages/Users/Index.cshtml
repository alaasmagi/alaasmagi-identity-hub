@page
@model Web.Areas.Admin.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<h1>Users</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input asp-for="Search" class="form-control" placeholder="Search users" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<table class="table">
    <thead>
    <tr>
        <th>Full name</th>
        <th>Email</th>
        <th>Active</th>
        <th>Banned</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var user in Model.Users?.Items ?? [])
    {
        <tr>
            <td>@user.FullName</td>
            <td>@user.Email</td>
            <td>@user.IsActive</td>
            <td>@user.IsBanned</td>
            <td class="text-end">
                <a asp-page="./Clients" asp-route-userId="@user.UserId" class="btn btn-sm btn-outline-primary">View Clients</a>
                <a asp-page="./Ban" asp-route-userId="@user.UserId" asp-route-isBanned="@user.IsBanned" class="btn btn-sm btn-outline-secondary">@(user.IsBanned ? "Unban" : "Ban")</a>
            </td>
        </tr>
    }
    </tbody>
</table>
