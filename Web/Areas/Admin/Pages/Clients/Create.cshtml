@page
@model Web.Areas.Admin.Pages.Clients.CreateModel
@{
    ViewData["Title"] = "Create Client";
}

<h1>Create Client</h1>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedSecret))
{
    <div class="alert alert-warning">
        <p><strong>Client secret shown once.</strong> Store it now; it cannot be viewed again.</p>
        <p><strong>Client ID:</strong> <code>@Model.GeneratedClientId</code></p>
        <p><strong>Client Secret:</strong> <code>@Model.GeneratedSecret</code></p>
    </div>
    <a asp-page="./Index" class="btn btn-primary">Back to Clients</a>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Name" class="form-control" placeholder="Name" />
                    <label asp-for="Input.Name" class="form-label"></label>
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.AllowedOrigins" class="form-control" placeholder="https://example.com" />
                    <label asp-for="Input.AllowedOrigins" class="form-label"></label>
                    <span asp-validation-for="Input.AllowedOrigins" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.RegistrationType" class="form-label"></label>
                    <select asp-for="Input.RegistrationType" asp-items="Model.RegistrationTypes" class="form-select"></select>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.IsActive" />
                    <label class="form-check-label" asp-for="Input.IsActive"></label>
                </div>
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
