@page
@model Web.Areas.Admin.Pages.Clients.EditModel
@{
    ViewData["Title"] = "Edit Client";
}

<h1>Edit Client</h1>

@if (!string.IsNullOrWhiteSpace(Model.GeneratedSecret))
{
    <div class="alert alert-warning">
        <p><strong>New client secret shown once.</strong> Store it now; it cannot be viewed again.</p>
        <p><strong>Client Secret:</strong> <code>@Model.GeneratedSecret</code></p>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.ClientId" />
            <div class="mb-3">
                <label class="form-label">Client ID</label>
                <input value="@Model.Input.ClientId" class="form-control" readonly />
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Name" class="form-control" placeholder="Name" />
                <label asp-for="Input.Name" class="form-label"></label>
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.AllowedOrigins" class="form-control" placeholder="https://example.com" />
                <label asp-for="Input.AllowedOrigins" class="form-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="Input.RegistrationType" class="form-label"></label>
                <select asp-for="Input.RegistrationType" asp-items="Model.RegistrationTypes" class="form-select"></select>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.IsActive" />
                <label class="form-check-label" asp-for="Input.IsActive"></label>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <button type="submit" asp-page-handler="RegenerateSecret" class="btn btn-outline-danger">Regenerate Secret</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Back</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
