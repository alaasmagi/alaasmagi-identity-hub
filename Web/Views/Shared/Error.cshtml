@model ErrorViewModel
@{
    ViewData["Title"] = L["Error"];
}

<h1 class="text-danger">@L["Error."]</h1>
<h2 class="text-danger">@L["An error occurred while processing your request."]</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>@L["Request ID:"]</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>@L["Development Mode"]</h3>
<p>
    @L["Swapping to"] <strong>Development</strong> @L["environment will display more detailed information about the error that occurred."]
</p>
<p>
    <strong>@L["The Development environment shouldn't be enabled for deployed applications."]</strong>
    @L["It can result in displaying sensitive information from exceptions to end users."]
    @L["For local debugging, enable the"] <strong>Development</strong> @L["environment by setting the"] <strong>ASPNETCORE_ENVIRONMENT</strong> @L["environment variable to"] <strong>Development</strong>
    @L["and restarting the app."]
</p>
